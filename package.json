{
  "name": "ghostcoach",
  "version": "2.1.12",
  "description": "Real-time Valorant AI coaching overlay",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "generate-icon": "node scripts/generate-icon.js",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist": "electron-builder --win --mac",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.ghostcoach.app2",
    "productName": "GhostCoach 2.0",
    "artifactName": "GhostCoach 2.0 Setup.${ext}",
    "copyright": "Copyright © 2025 GhostCoach",
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GhostCoach 2.0",
      "uninstallDisplayName": "GhostCoach 2.0",
      "include": "build/uninstaller.nsh"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "lowful",
      "repo": "GhostCoach-releases",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "keywords": [
    "electron",
    "gaming",
    "ai",
    "overlay",
    "coach"
  ],
  "author": "GhostCoach",
  "license": "MIT"
}
