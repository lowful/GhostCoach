# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe dashboard or via setup script)
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# App URLs
CLIENT_URL=https://ghostcoachai.com

# ─── AI model provider ────────────────────────────────────────────────────────
# Leave AI_API_KEY empty to keep using Gemini (GEMINI_API_KEY).
# To switch to OpenRouter + Qwen2.5-VL (recommended, prepaid, cheap):
#   1. Create an OpenRouter account and add credits, copy your key (sk-or-...).
#   2. Set the vars below and redeploy.
# Any OpenAI-compatible endpoint works: just change AI_BASE_URL + model slugs.
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
# Qwen3-VL is great at reading game HUDs. Pricing per 1M tokens:
#   qwen/qwen3-vl-235b-a22b-thinking  reasons before answering, best on the hard
#                                     reads (side, minimap), slower, DEFAULT
#   qwen/qwen3-vl-235b-a22b-instruct  $0.20 in / $0.88 out   (fast, no reasoning)
#   qwen/qwen3-vl-30b-a3b-instruct    $0.13 in / $0.52 out   (cheapest/fastest)
# Thinking models spend output tokens reasoning, so the server adds reasoning
# headroom on top of each answer budget automatically (see chatCall).
AI_VISION_MODEL=qwen/qwen3-vl-235b-a22b-thinking
AI_TEXT_MODEL=qwen/qwen3-vl-235b-a22b-thinking
# AI_PROVIDER=openai   # auto-set to 'openai' when AI_API_KEY is present; 'gemini' otherwise

# Existing (unchanged)
# GEMINI_API_KEY=...

# Tracker.gg API key (tracker.gg/developers). Powers /player-stats, which feeds
# rank / K/D / headshot% into live tips and Ask Coach. Set the real key in
# Railway Variables. If tracker.gg blocks the server (Cloudflare on datacenter
# IPs), get a free HenrikDev key (docs.henrikdev.xyz) as the fallback source.
TRACKER_API_KEY=
HENRIKDEV_API_KEY=
