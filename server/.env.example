# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe dashboard or via setup script)
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# App URLs
CLIENT_URL=https://ghostcoachai.com

# ─── AI model provider ────────────────────────────────────────────────────────
# Leave AI_API_KEY empty to keep using Gemini (GEMINI_API_KEY).
# To switch to OpenRouter + Qwen2.5-VL (recommended, prepaid, cheap):
#   1. Create an OpenRouter account and add credits, copy your key (sk-or-...).
#   2. Set the vars below and redeploy.
# Any OpenAI-compatible endpoint works: just change AI_BASE_URL + model slugs.
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
# Qwen3-VL is new, cheap, and great at reading game HUDs. Pricing per 1M tokens:
#   qwen/qwen3-vl-30b-a3b-instruct    $0.13 in / $0.52 out   (fast, best value, DEFAULT)
#   qwen/qwen3-vl-235b-a22b-instruct  $0.20 in / $0.88 out   (smartest, a bit slower)
#   qwen/qwen3-vl-8b-instruct         $0.08 in / $0.50 out   (cheapest/fastest)
AI_VISION_MODEL=qwen/qwen3-vl-30b-a3b-instruct
AI_TEXT_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# AI_PROVIDER=openai   # auto-set to 'openai' when AI_API_KEY is present; 'gemini' otherwise

# Existing (unchanged)
# GEMINI_API_KEY=...
